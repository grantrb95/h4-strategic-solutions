# Anthropic API Key (required)
ANTHROPIC_API_KEY=your-api-key-here

# GitHub Personal Access Token (required for Code Assistant agent)
# Needs "Contents: Read and write" permission on grantrb95/h4-strategic-solutions
GITHUB_TOKEN=ghp_your-token-here

# Agent IDs (populated by running: npm run setup)
AGENT_ID_QUOTE_INTAKE=
AGENT_ID_MARKET_RESEARCH=
AGENT_ID_DOC_PROCESSING=
AGENT_ID_CODE_ASSISTANT=
AGENT_ID_FINANCE=

# Environment ID (populated by running: npm run setup)
ENVIRONMENT_ID=

# Vault ID (populated by running: npx tsx src/setup-vault.ts)
VAULT_ID_GITHUB=

# GitHub MCP OAuth (required for vault setup — enables PR creation)
# See: https://platform.claude.com/docs/en/managed-agents/vaults
GITHUB_MCP_ACCESS_TOKEN=
GITHUB_MCP_REFRESH_TOKEN=
GITHUB_MCP_CLIENT_ID=
GITHUB_MCP_CLIENT_SECRET=

# Slack Webhook URL (optional — posts daily market reports to Slack)
SLACK_WEBHOOK_URL=

# Cron Secret (optional — secures the /api/market-report endpoint)
CRON_SECRET=

# Formspree Webhook Secret (optional — validates webhook signatures)
WEBHOOK_SECRET=
