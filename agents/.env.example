# Anthropic API Key (required)
ANTHROPIC_API_KEY=your-api-key-here

# GitHub Personal Access Token (required for Code Assistant agent)
# Needs "Contents: Read and write" permission on grantrb95/h4-strategic-solutions
GITHUB_TOKEN=ghp_your-token-here

# Agent IDs (populated by running: npm run setup)
AGENT_ID_QUOTE_INTAKE=
AGENT_ID_MARKET_RESEARCH=
AGENT_ID_DOC_PROCESSING=
AGENT_ID_CODE_ASSISTANT=

# Environment ID (populated by running: npm run setup)
ENVIRONMENT_ID=
